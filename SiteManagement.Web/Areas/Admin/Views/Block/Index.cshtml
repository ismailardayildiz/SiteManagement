@using SiteManagement.Entity.DTOs.Blocks
@model List<BlockDto>
@{
    ViewData["Title"] = "Blok Yönetimi";
}

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Blok Yönetimi /</span> Bloklar</h4>
    <div class="card">
        <div class="card-header">
            <a class="btn btn-primary" asp-area="Admin" asp-controller="Block" asp-action="Add">
                Blok Ekle <i class="bx bx-plus"></i>
            </a>
        </div>
        <div class="table-responsive text-nowrap">
            <table class="table table-hover" id="blocksTable">
                <thead>
                    <tr>
                        <th>Blok Adı</th>
                        <th>Kat Sayısı</th>
                        <th>Bağlı Olduğu Site</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var block in Model)
                    {
                        <tr name="@block.Id">
                            <td>@block.Name</td>
                            <td><span class="badge bg-label-info">@block.FloorCount Kat</span></td>
                            <td>@block.SiteName</td>
                            <td><span class="badge bg-label-success">Aktif</span></td>
                            <td>
                                <button class="btn btn-sm btn-primary" data-id="@block.Id" id="updateBlock">
                                    <i class="bx bxs-edit"></i>
                                </button>
                                <button class="btn btn-sm btn-danger" data-id="@block.Id" id="deleteBlock">
                                    <i class="bx bx-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="modalPlaceHolder" aria-hidden="true"></div>

@section Scripts {
    <script src="~/js/blockIndex.js"></script>
}