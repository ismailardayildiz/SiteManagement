@{
    ViewData["Title"] = "Daire Yönetimi";
}
<style>
    .swal2-container {
        z-index: 10000 !important;
    }
</style>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Daire Listesi</h5>
        <button type="button" class="btn btn-primary" onclick="openAddModal()">Yeni Daire Ekle</button>
    </div>
    <div class="card-body">
        <div class="table-responsive text-nowrap">
            <table class="table table-bordered table-hover" id="apartmentsTable" width="100%">
                <thead>
                    <tr>
                        <th>Site Adı</th>
                        <th>Blok Adı</th>
                        <th>Kat No</th>
                        <th>Daire No</th>
                        <th>Metrekare</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="apartmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Yeni Daire Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="apartmentForm">
                <div class="modal-body">
                    <input type="hidden" id="ApartmentId" name="Id" />
                    <div class="mb-3">
                        <label class="form-label">Site</label>
                        <select id="SiteId" name="SiteId" class="form-select" onchange="loadBlocks()" required>
                            <option value="">Site Seçiniz</option>
                            @foreach (var site in ViewBag.Sites)
                            {
                                <option value="@site.Value">@site.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Blok</label>
                        <select id="BlockId" name="BlockId" class="form-select" required>
                            <option value="">Önce Site Seçiniz</option>
                        </select>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col mb-0">
                            <label class="form-label">Kat No</label>
                            <input type="number" id="Floor" name="Floor" class="form-control" required />
                        </div>
                        <div class="col mb-0">
                            <label class="form-label">Daire No</label>
                            <input type="text" id="ApartmentNumber" name="ApartmentNumber" class="form-control" required />
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col mb-0">
                            <label class="form-label">Metrekare</label>
                            <input type="number" step="0.01" id="SquareMeters" name="SquareMeters" class="form-control" required />
                        </div>
                        <div class="col mb-0">
                            <label class="form-label">Oda Sayısı</label>
                            <input type="number" id="RoomCount" name="RoomCount" class="form-control" required />
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col mb-0">
                            <label class="form-label">Ev Sahibi</label>
                            <select id="OwnerId" name="OwnerId" class="form-select select2">
                                <option value="">(Seçilmedi - Boş)</option>
                                @foreach (var user in ViewBag.Users)
                                {
                                    <option value="@user.Value">@user.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col mb-0">
                            <label class="form-label">Kiracı</label>
                            <select id="TenantId" name="TenantId" class="form-select select2">
                                <option value="">(Kiracı Yok)</option>
                                @foreach (var user in ViewBag.Users)
                                {
                                    <option value="@user.Value">@user.Text</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Kapat</button>
                    <button type="button" class="btn btn-primary" onclick="saveApartment()">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var dataTable;

        $(document).ready(function () {
            loadDataTable();
        });

        function loadDataTable() {
            dataTable = $('#apartmentsTable').DataTable({
                ajax: { url: '/Admin/Apartment/GetApartments' },
                columns: [
                    { data: 'siteName' },
                    { data: 'blockName' },
                    { data: 'floor' },
                    { data: 'apartmentNumber' },
                    { data: 'squareMeters' },
                    {
                        data: 'status',
                        render: function (data) {
                            var badge = data === 'Boş' ? 'bg-label-warning' : (data === 'Kiracı' ? 'bg-label-info' : 'bg-label-success');
                            return `<span class="badge ${badge}">${data}</span>`;
                        }
                    },
                    {
                        data: 'id',
                        render: function (data) {
                            return `
                                <button class="btn btn-sm btn-icon btn-primary" onclick="openEditModal('${data}')"><i class="bx bx-edit"></i></button>
                                <button class="btn btn-sm btn-icon btn-danger" onclick="deleteApartment('${data}')"><i class="bx bx-trash"></i></button>
                            `;
                        }
                    }
                ],
                language: { url: "//cdn.datatables.net/plug-ins/1.10.24/i18n/Turkish.json" }
            });
        }

        function loadBlocks(selectedBlockId = null) {
            var siteId = $("#SiteId").val();
            var blockSelect = $("#BlockId");
            blockSelect.empty().append('<option value="">Blok Seçiniz</option>');

            if (siteId) {
                $.get('/Admin/Apartment/GetBlocksBySiteId', { siteId: siteId }, function (data) {
                    $.each(data, function (index, item) {
                        var selected = (item.id === selectedBlockId) ? "selected" : "";
                        blockSelect.append(`<option value="${item.id}" ${selected}>${item.name}</option>`);
                    });
                });
            }
        }

        function openAddModal() {
            $('#apartmentForm')[0].reset();
            $('#ApartmentId').val('');
            $('#modalTitle').text('Yeni Daire Ekle');
            $('#BlockId').empty().append('<option value="">Önce Site Seçiniz</option>');
            $('#apartmentModal').modal('show');
        }

               function openEditModal(id) {
            $.get('/Admin/Apartment/GetApartment/' + id, function (data) {
                $('#ApartmentId').val(data.id);
                $('#SiteId').val(data.siteId);
                loadBlocks(data.blockId);
                $('#Floor').val(data.floor);
                $('#ApartmentNumber').val(data.apartmentNumber);
                $('#SquareMeters').val(data.squareMeters);
                $('#RoomCount').val(data.roomCount);

                // Yeni Dropdown değerlerini set et
                $('#OwnerId').val(data.ownerId).trigger('change');
                $('#TenantId').val(data.tenantId).trigger('change');

                $('#modalTitle').text('Daire Güncelle');
                $('#apartmentModal').modal('show');
            });
        }

        function saveApartment() {
            var formData = $('#apartmentForm').serialize();
            var id = $('#ApartmentId').val();
            var url = id ? '/Admin/Apartment/Update' : '/Admin/Apartment/Add';

            $.post(url, formData, function (res) {
                if (res.success) {
                    $('#apartmentModal').modal('hide');
                    dataTable.ajax.reload();
                    Swal.fire('Başarılı!', res.message, 'success');
                } else {
                    Swal.fire('Hata!', res.message, 'error');
                }
            });
        }

        function deleteApartment(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu daire silinecektir! (Soft Delete)",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Evet, sil!',
                cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Admin/Apartment/Delete', { id: id }, function (res) {
                        if (res.success) {
                            dataTable.ajax.reload();
                            Swal.fire('Silindi!', res.message, 'success');
                        }
                    });
                }
            });
        }
    </script>

}
