@model List<UserDto>

<div id="modalPlaceHolder"></div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Kullanıcı Listesi</h5>
        <button type="button" class="btn btn-success" data-toggle="ajax-modal" data-url="@Url.Action("Add", "User", new { Area = "Admin" })">
            Yeni Kullanıcı Ekle
        </button>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Ad Soyad</th>
                    <th>Email</th>
                    <th>Telefon</th>
                    <th>Rol</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.FirstName @user.LastName</td>
                        <td>@user.Email</td>
                        <td>@user.PhoneNumber</td>
                        <td><span class="badge bg-label-info me-1">@user.Role</span></td>
                        <td>
                            <button type="button" class="btn btn-sm btn-info" data-toggle="ajax-modal" data-url="@Url.Action("Detail", "User", new { Area = "Admin", userId = user.Id })">
                                Detay
                            </button>

                            <button type="button" class="btn btn-sm btn-primary" data-toggle="ajax-modal" data-url="@Url.Action("Update", "User", new { Area = "Admin", userId = user.Id })">
                                Güncelle
                            </button>

                            <form asp-area="Admin" asp-controller="User" asp-action="Delete" method="post" style="display:inline;" onsubmit="return confirm('Bu kullanıcıyı silmek istediğinize emin misiniz?');">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var placeholderElement = $('#modalPlaceHolder');

            // 1. MODALI AÇMA İŞLEMİ (Butonun çalışmasını sağlayan kısım)
            // Dinamik olarak yüklenen butonlar için .on('click') kullanmak daha güvenlidir
            $(document).on('click', 'button[data-toggle="ajax-modal"]', function (event) {
                var url = $(this).data('url');
                $.get(url).done(function (data) {
                    placeholderElement.html(data);
                    placeholderElement.find('.modal').modal('show');
                });
            });

            // 2. FORMU KAYDETME İŞLEMİ (Resim yükleme destekli FormData yapısı)
            placeholderElement.off('click', '[data-save="modal"]').on('click', '[data-save="modal"]', function (event) {
                event.preventDefault();

                var button = $(this);
                var form = button.parents('.modal').find('form');
                var actionUrl = form.attr('action');

                // KRİTİK: Resim dosyasının gidebilmesi için FormData kullanıyoruz, serialize() DEĞİL!
                var sendData = new FormData(form[0]);

                // Çift tıklamayı önlemek için butonu pasif yap
                button.prop('disabled', true);

                $.ajax({
                    url: actionUrl,
                    type: 'POST',
                    data: sendData,
                    processData: false, // JQuery'nin veriyi bozmasını engeller
                    contentType: false, // Multipart/form-data sınırlarının korunmasını sağlar
                    success: function (data) {
                        if (data.success) {
                            placeholderElement.find('.modal').modal('hide');
                            location.reload();
                        } else {
                            // Validasyon hatası varsa formu hatalarla birlikte tekrar çiz
                            placeholderElement.html(data);
                            if(placeholderElement.find('.modal').length) {
                                 placeholderElement.find('.modal').modal('show');
                            }
                        }
                    },
                    error: function (err) {
                        console.error("Sunucu hatası:", err);
                        alert("Kayıt işlemi sırasında bir hata oluştu.");
                    },
                    complete: function () {
                        // İşlem bitince butonu tekrar aktif et
                        button.prop('disabled', false);
                    }
                });
            });
        });
    </script>
}