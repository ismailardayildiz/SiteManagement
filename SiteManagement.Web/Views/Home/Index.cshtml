@{
    ViewData["Title"] = "Ana Sayfa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold text-dark"><i class='bx bx-home-smile text-primary'></i> Hoş Geldiniz</h2>
            <p class="text-muted">Site yönetim panelinizden güncel duyuruları ve finansal durumunuzu takip edebilirsiniz.</p>
        </div>
    </div>

    <div class="row">
        <!-- Ödenmemiş Aidatlar / Bekleyen Ödemeler Kartı -->
        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm border-0 h-100" style="border-left: 4px solid #dc3545 !important;">
                <div class="card-header bg-white border-0 pt-4 pb-2">
                    <h5 class="card-title text-danger fw-bold mb-0">
                        <i class='bx bx-error-circle fs-4 align-middle me-1'></i> Bekleyen Ödemeleriniz
                    </h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.UnpaidDues != null && Enumerable.Count(ViewBag.UnpaidDues) > 0)
                    {
                        <ul class="list-group list-group-flush mb-3">
                            @foreach (var due in ViewBag.UnpaidDues)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0 border-bottom">
                                    <div>
                                        <h6 class="mb-1 fw-bold text-dark">@due.Month @due.Year Aidatı</h6>
                                        <small class="text-muted">
                                            <i class='bx bx-calendar-event'></i> Son Ödeme: @due.DueDate.ToString("dd.MM.yyyy")
                                        </small>
                                    </div>
                                    <span class="badge bg-danger rounded-pill fs-6 px-3 py-2">@due.Amount ₺</span>
                                </li>
                            }
                        </ul>
                        <a href="/Due/Index" class="btn btn-outline-danger w-100 fw-bold">
                            <i class='bx bx-credit-card'></i> Tümünü Gör ve Öde
                        </a>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <div class="bg-success-subtle text-success rounded-circle d-inline-flex p-3 mb-3">
                                <i class='bx bx-check-double fs-1'></i>
                            </div>
                            <h6 class="text-success fw-bold">Harika!</h6>
                            <p class="text-muted mb-0">Gecikmiş veya bekleyen hiçbir aidat borcunuz bulunmuyor.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Güncel Duyurular Kartı -->
        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm border-0 h-100" style="border-left: 4px solid #0d6efd !important;">
                <div class="card-header bg-white border-0 pt-4 pb-2">
                    <h5 class="card-title text-primary fw-bold mb-0">
                        <i class='bx bx-megaphone fs-4 align-middle me-1'></i> Son Duyurular
                    </h5>
                </div>
                <div class="card-body p-0">
                    @if (ViewBag.Announcements != null && Enumerable.Count(ViewBag.Announcements) > 0)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var announcement in ViewBag.Announcements)
                            {
                                <div class="list-group-item px-4 py-3 border-bottom">
                                    <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                                        <h6 class="mb-0 fw-bold text-dark">@announcement.Title</h6>
                                        <small class="text-muted" style="font-size: 0.8rem;">
                                            <i class='bx bx-time-five'></i> @announcement.CreatedDate.ToString("dd.MM.yyyy")
                                        </small>
                                    </div>
                                    <p class="mb-0 text-muted" style="font-size: 0.9rem;">
                                        @announcement.Content
                                    </p>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class='bx bx-info-circle text-muted fs-1 mb-2'></i>
                            <p class="text-muted mb-0">Şu anda sistemde yayınlanmış bir duyuru bulunmuyor.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>